# ====================================
# APP
# ====================================
APP_NAME=RutAI Backend
DEBUG=False

# ====================================
# BASE DE DATOS (Supabase — Transaction Pooler)
# ====================================
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_password_here
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
# Para PostgreSQL local descomenta esto y comenta lo anterior:
# DB_USER=postgres
# DB_PASSWORD=your_local_password_here
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rutai_db

# ====================================
# JWT
# ====================================
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ====================================
# API
# ====================================
API_BASE_URL=https://your-domain.com

# ====================================
# CORS
# ====================================
ALLOWED_ORIGINS=http://localhost:3000,exp://127.0.0.1:19000

# ====================================
# FIREBASE FCM
# Pegar el JSON completo de Firebase en una sola línea
# ====================================
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ====================================
# EXPERIMENTO GEOFENCING
# ====================================
GEOFENCE_MATCH_WINDOW_SECONDS=30
